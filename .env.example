NODE_ENV=development
PORT=3000
LOG_LEVEL=info

DATABASE_URL=postgres://bulk_user:bulk_pass@127.0.0.1:5432/bulk_validation
REDIS_URL=redis://127.0.0.1:6379

GS1_BASE_URL=https://api.gs1datakart.org
GS1_PRODUCTS_PATH=/console/retailer/products
GS1_TOKEN=replace_me
GS1_TIMEOUT_MS=15000
GS1_MAX_RETRIES=5
GS1_BACKOFF_BASE_MS=1000

DOWNSTREAM_URL=https://dk-app.org/store_product_auto_validate
DOWNSTREAM_TIMEOUT_MS=10000
DELIVERY_MAX_RETRIES=5
DELIVERY_BATCH_SIZE=100
# Delay before each batch is eligible for delivery (hours). Use 2 to collect validated queue for 2h then push. 0 = deliver immediately.
DELIVERY_DELAY_HOURS=2

# Hourly publish: PUT cumulative validated results for the day. Body: {"data":[{ "GTIN_number", "Status", "Reason", "Date" }, ...]}
HOURLY_PUBLISH_URL=http://localhost:3000/store_product_auto_validate

# Main use-case app: CSV with full column set (Company Name, AI Verified Status, GTIN, ...). Sent every hour. POST body = CSV.
MAIN_APP_CSV_URL=
# MAIN_APP_CSV_TIMEOUT_MS=60000

RAW_QUEUE_HIGH_WATERMARK=200
RAW_QUEUE_CONCURRENCY=5
VALIDATED_QUEUE_CONCURRENCY=5
