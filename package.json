{
  "name": "bulk-validation-pipeline",
  "version": "1.0.0",
  "description": "Production-oriented bulk validation pipeline with cursor ingestion, queue workers, delivery outbox, and reporting.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "migrate": "node src/scripts/migrate.js",
    "worker:ingestion": "node src/workers/ingestionRunner.js",
    "worker:validation": "node src/workers/validationWorker.js",
    "worker:delivery": "node src/workers/deliveryWorker.js",
    "worker:outbox-replay": "node src/workers/outboxReplayWorker.js",
    "worker:report-scheduler": "node src/workers/reportSchedulerWorker.js",
    "worker:hourly-publish": "node src/workers/hourlyPublishWorker.js",
    "report:daily": "node src/scripts/generateDailyReport.js",
    "test": "node --test",
    "loadtest": "node src/scripts/loadtest.js",
    "validate:day": "node src/scripts/runPreviousDay.js",
    "monitor": "node src/scripts/monitorRun.js",
    "monitor:reports": "node src/scripts/monitorWithReports.js",
    "monitor:view": "node src/scripts/viewMonitoring.js",
    "check:newdata": "node src/scripts/checkNewData.js",
    "diagnose": "node src/scripts/diagnose.js",
    "analyze:discrepancy": "node src/scripts/analyzeDiscrepancy.js",
    "compare:queries": "node src/scripts/compareQueries.js",
    "verify:continuous": "node src/scripts/verifyContinuousValidation.js",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:down:volumes": "docker compose down -v"
  },
  "dependencies": {
    "axios": "^1.8.1",
    "bullmq": "^5.40.3",
    "csv-stringify": "^6.5.2",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "prom-client": "^15.1.3",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  }
}
